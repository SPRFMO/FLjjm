#!/bin/sh

# Call where.exe directly - avoids cmd.exe version banner
ADMB_PATH=$(/c/Windows/System32/where.exe admb 2>/dev/null | head -1 | tr -d '\r')

if [ -n "$ADMB_PATH" ]; then
    echo "ADMB found at: $ADMB_PATH"
    echo "HAVE_ADMB=1" > src/Makevars.local
    echo "ADMB_EXE=$ADMB_PATH" >> src/Makevars.local
else
    echo "ADMB not found; using bundled binaries"
    echo "HAVE_ADMB=0" > src/Makevars.local
    echo "ADMB_EXE=admb" >> src/Makevars.local
fi
